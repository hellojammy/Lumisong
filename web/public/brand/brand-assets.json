  "rules": {
    "use": [
      "five primary sound-event nodes",
      "faint secondary event dots",
      "one cyan playback light path",
      "one small orange energy accent",
      "subtle dense perspective grid"
    ],
    "avoid": [
      "birds",
      "music notes",
      "microphones",
      "vinyl records",
      "headphones",
      "waveform bars",
      "staff notation",
      "literal galaxy spirals"
    ]
